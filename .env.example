# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=sss
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sss_platform

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change_me_at_least_32_random_chars
FERNET_KEY=YlVYalI0YW9QY2tOalR4OTBNeURuMERvcElLd29OWlE=

# ── AI Providers ─────────────────────────────────────────────────
# API key is shared across NVIDIA NIM models. Keep real keys in .env only.
AI_PROVIDER=auto
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Chat/completions model used by AI round2 security analysis.
NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_THINKING=false

# Future adapters can use these NVIDIA models. Leave adapter API keys empty
# to fall back to NVIDIA_API_KEY, or set them when a model uses a different key.
NVIDIA_PII_MODEL=nvidia/gliner-pii
NVIDIA_PII_API_KEY=
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1
NVIDIA_EMBED_API_KEY=
NVIDIA_CODE_EMBED_MODEL=nvidia/nv-embedcode-7b-v1
NVIDIA_CODE_EMBED_API_KEY=
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
NVIDIA_RERANK_MODEL=nv-rerank-qa-mistral-4b:1
NVIDIA_RERANK_API_KEY=

ANTHROPIC_API_KEY=
# Optional fallback
GEMINI_API_KEY=

# ── Scan Settings ─────────────────────────────────────────────────
SCAN_DATA_PATH=/data/scans
MAX_CRAWL_DEPTH=5
MAX_CRAWL_PAGES=500
MAX_RESOURCE_SIZE_MB=10
CRAWL_CONCURRENCY=5
ALLOW_PRIVATE_TARGETS=false
SSRF_ALLOWED_HOSTS=vulnerable-site,host.docker.internal

# ── Browser Auth ─────────────────────────────────────────────────
BROWSER_AUTH_MODE=manual
E2E_BROWSER_AUTH_ENABLED=false
E2E_BROWSER_AUTH_ALLOWED_HOSTS=vulnerable-site,localhost,127.0.0.1
E2E_BROWSER_AUTH_EMAIL=demo@example.com
E2E_BROWSER_AUTH_PASSWORD=password123!

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
