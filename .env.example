# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=sss
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sss_platform

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change_me_at_least_32_random_chars
FERNET_KEY=change_me_32_url_safe_base64_key==

# ── AI Providers ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallback
GEMINI_API_KEY=

# ── Scan Settings ─────────────────────────────────────────────────
SCAN_DATA_PATH=/data/scans
MAX_CRAWL_DEPTH=5
MAX_CRAWL_PAGES=500
MAX_RESOURCE_SIZE_MB=10
CRAWL_CONCURRENCY=5

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=http://localhost,https://localhost
